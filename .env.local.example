# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.local.example is the public template.
#
# All variables below are consumed by the Backend admin surface. The Frontend
# never reads any of these directly — it talks to /api/admin/** which reads
# them server-side.

# ─── Database (M1) ────────────────────────────────────────────────────────────
# Vercel Postgres / Neon connection string. Format:
#   postgres://USER:PASS@HOST/DBNAME?sslmode=require
# Consumed by: db/client.ts (via @vercel/postgres) and drizzle.config.ts.
POSTGRES_URL=postgres://user:password@host:5432/metaborong?sslmode=require

# ─── Auth (M1) ────────────────────────────────────────────────────────────────
# Random ≥32-char secret used to sign mb_admin_session JWTs (HS256, jose).
# Generate with:  openssl rand -base64 48
# Consumed by: lib/auth.ts (createSession / verifySession).
AUTH_SECRET=replace-with-at-least-32-characters-of-random-bytes

# Single-admin credentials. Email is compared case-insensitively. Password is
# bcrypt-hashed with cost 12; generate the hash with a one-off script:
#   node -e "import('bcryptjs').then(m=>m.hash('your-password',12).then(console.log))"
# Consumed by: app/api/admin/login/route.ts.
#
# !!! IMPORTANT: ESCAPE EVERY $ IN THE BCRYPT HASH AS \$ BELOW. !!!
# Next.js loads .env.local through dotenv-expand, which interprets unescaped
# `$tokens` as variable references. A bcrypt hash starts with `$2b$12$...`,
# and without escapes Next will substitute `$2b`, `$12`, etc. with empty
# strings — silently mangling the hash so the route handler always returns
# 401 even when the password is correct. Single quotes do NOT prevent this;
# only backslash escapes do. Caught the hard way during M1 manual testing.
ADMIN_EMAIL=admin@metaborong.com
ADMIN_PASSWORD_HASH=\$2b\$12\$replace_this_with_a_real_bcrypt_hash_generated_locally....

# ─── Vercel Blob (M4) ─────────────────────────────────────────────────────────
# Read/write token for @vercel/blob. Get one from the Vercel Dashboard:
#   Storage → Blob → "Connect Project" → Generate Token. Production tokens
#   are scoped per environment.
# Consumed by: lib/images.ts (via @vercel/blob's put / del).
#
# !!! IMPORTANT: ESCAPE EVERY $ IN THE TOKEN VALUE AS \$ BELOW. !!!
# Same dotenv-expand caveat as ADMIN_PASSWORD_HASH above — Vercel Blob
# tokens commonly contain `$` separators (e.g. `vercel_blob_rw_<id>$<secret>`).
# Without escapes, Next.js's dotenv-expand substitutes `$<secret>` with the
# empty string and the token silently mangles, causing every blob write to
# fail with an opaque "invalid token" error. Backslash-escape each `$`.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_with_real_token_from_dashboard

# ─── Local geo override (already in use) ──────────────────────────────────────
# Optional. Used only in development by app/api/consent/route.ts when no
# Vercel geo headers are present, so the geo path can be exercised on
# localhost without a Vercel preview deploy.
# DEV_GEO_COUNTRY=US
# DEV_GEO_REGION=California
# DEV_GEO_CITY=San Francisco

# ─── AI Readiness MCP (M7 — VerseOdin) ────────────────────────────────────────
# Endpoint, bearer token, and tool name for the VerseOdin MCP server that scores
# a published-post URL for AI / LLM-citation readiness. All three must be set or
# the "Check AI Readiness" button hides in the editor and the proxy endpoint
# returns 503 with code MCP_DISABLED (PRD §5.10).
#
# Tool input shape (per VerseOdin docs):
#   { "url": "https://www.metaborong.com/blog/<slug>/" }
# Because the tool consumes a URL (not raw content), only PUBLISHED posts are
# scoreable in v1.5; pre-publish scoring requires a tokenized preview URL and
# is deferred to v1.6.
#
# Bearer token: the value is a secret. Treat the same way as ADMIN_PASSWORD_HASH
# and BLOB_READ_WRITE_TOKEN — backslash-escape any `$` characters to defeat
# dotenv-expand's variable interpolation (e.g. `vso_xxx\$yyy`).
AI_READINESS_MCP_URL=https://verseodin.com/api/mcp
AI_READINESS_MCP_AUTH_TOKEN=vso_replace_with_real_bearer_from_friend
AI_READINESS_MCP_TOOL_NAME=ai_readiness_scan
